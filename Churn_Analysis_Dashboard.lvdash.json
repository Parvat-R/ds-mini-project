{
  "datasets": [
    {
      "name": "dataset1",
      "displayName": "train_test_table",
      "queryLines": [
        "SELECT * FROM workspace.`ds-datasets`.train_test_table"
      ],
      "columns": [
        {
          "displayName": "Churn Status",
          "description": "Customer churn indicator",
          "expression": "CASE WHEN `Target` = 1 THEN 'Churned' ELSE 'Retained' END"
        },
        {
          "displayName": "Tenure Segment",
          "description": "Customer tenure grouping",
          "expression": "CASE WHEN `Tenure_Years` < 1 THEN '< 1 year' WHEN `Tenure_Years` < 3 THEN '1-3 years' WHEN `Tenure_Years` < 5 THEN '3-5 years' ELSE '5+ years' END"
        },
        {
          "displayName": "Payment Method",
          "description": "Payment method type",
          "expression": "CASE WHEN `is_card_payment` = 1 THEN 'Card Payment' ELSE 'Other Payment' END"
        },
        {
          "displayName": "Has Anchoring",
          "description": "Current anchoring status",
          "expression": "CASE WHEN `Current_Anchorings` > 0 THEN 'Has Anchoring' ELSE 'No Anchoring' END"
        },
        {
          "displayName": "Sentiment Category",
          "description": "Sentiment score category",
          "expression": "CASE WHEN `crm_contractor_sentiment_score` >= 0.7 THEN 'Positive' WHEN `crm_contractor_sentiment_score` >= 0.4 THEN 'Neutral' ELSE 'Negative' END"
        },
        {
          "displayName": "Join Year",
          "description": "Estimated year customer joined based on tenure",
          "expression": "CAST(2026 - FLOOR(`Tenure_Years`) AS STRING)"
        },
        {
          "displayName": "Join Quarter",
          "description": "Estimated quarter customer joined",
          "expression": "CONCAT('Q', CAST(CEIL((12 - ((`Tenure_Years` - FLOOR(`Tenure_Years`)) * 12)) / 3) AS STRING), ' ', CAST(2026 - FLOOR(`Tenure_Years`) AS STRING))"
        },
        {
          "displayName": "Tenure Group",
          "description": "Granular tenure grouping",
          "expression": "CASE WHEN `Tenure_Years` < 0.5 THEN '0-6 months' WHEN `Tenure_Years` < 1 THEN '6-12 months' WHEN `Tenure_Years` < 2 THEN '1-2 years' WHEN `Tenure_Years` < 3 THEN '2-3 years' WHEN `Tenure_Years` < 5 THEN '3-5 years' ELSE '5+ years' END"
        },
        {
          "displayName": "Join Month",
          "description": "Estimated year-month customer joined (YYYY-MM format)",
          "expression": "CONCAT(CAST(2026 - FLOOR(`Tenure_Years`) AS STRING), '-', LPAD(CAST(CAST(12 - ((`Tenure_Years` - FLOOR(`Tenure_Years`)) * 12) AS INT) AS STRING), 2, '0'))"
        },
        {
          "displayName": "Sentiment Data Status",
          "description": "Whether sentiment data is available or missing",
          "expression": "CASE WHEN `crm_sentiment_missing` = 1 THEN 'Sentiment Missing' ELSE 'Sentiment Available' END"
        }
      ]
    }
  ],
